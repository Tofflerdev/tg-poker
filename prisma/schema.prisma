generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                Int       @id @default(autoincrement())
  telegramId        BigInt    @unique @map("telegram_id")
  telegramUsername  String?   @map("telegram_username") @db.VarChar(255)
  displayName       String    @map("display_name") @db.VarChar(50)
  avatarUrl         String?   @map("avatar_url")
  balance           Int       @default(1000)
  lastDailyRefill   DateTime? @map("last_daily_refill") @db.Timestamptz
  handsPlayed       Int       @default(0) @map("hands_played")
  handsWon          Int       @default(0) @map("hands_won")
  totalWinnings     Int       @default(0) @map("total_winnings")
  biggestPot        Int       @default(0) @map("biggest_pot")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // --- v1_mvp_launch additions ---
  avatarId          String?
  currentTableId    String?
  currentSeat       Int?
  currentChips      Int?
  sessionToken      String?
  disconnectedAt    DateTime?
  lastSeenAt        DateTime?
  bannedAt          DateTime?
  tosAcceptedAt     DateTime?
  tosVersion        String?

  // --- playtest bots ---
  isBot             Boolean   @default(false) @map("is_bot")

  // --- crypto-payments-rake phase 1: ledger ---
  transactions      Transaction[]

  @@index([currentTableId])
  @@map("users")
}

// crypto-payments-rake phase 1 — append-only money ledger.
// Every balance mutation writes exactly one Transaction row inside the same
// DB transaction as the balance UPDATE (see UserRepository). `amount` is a
// signed chip delta (1 chip = 0.01 USDT peg). `balanceAfter` snapshots the
// user's balance immediately after this entry. `externalId` is @unique to
// make deposit/withdrawal webhooks idempotent (phase 4/5). Never UPDATE or
// DELETE rows — corrections are new `adjustment` entries.
enum TransactionType {
  deposit
  withdrawal
  buyin
  cashout
  rake
  bonus
  adjustment
  fee
}

enum TransactionStatus {
  pending
  completed
  failed
}

model Transaction {
  id           String            @id @default(cuid())
  userId       Int?              @map("user_id")
  user         User?             @relation(fields: [userId], references: [id])
  type         TransactionType
  amount       Int
  // Nullable: system rows with no single owning balance (e.g. a `rake` row while
  // the house account is not yet introduced — plan §H, deferred) carry null.
  // User-scoped rows (buyin/cashout/bonus/adjustment/deposit/withdrawal) always set it.
  balanceAfter Int?              @map("balance_after")
  externalId   String?           @unique @map("external_id")
  status       TransactionStatus @default(completed)
  meta         Json?
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@map("transactions")
}

model HandHistory {
  id         String   @id @default(cuid())
  handId     String
  telegramId String
  tableId    String
  playedAt   DateTime @default(now())
  board      String[]
  holeCards  String[]
  seat       Int
  netDelta   Int
  finalChips Int
  showedDown Boolean
  won        Boolean
  // crypto-payments-rake phase 2: total chips raked in THIS hand, denormalized
  // onto every player row of the hand (same value across a handId). The ledger
  // (Transaction type='rake') is the source of truth for totals — to sum rake
  // from here, dedupe by handId first.
  rake       Int      @default(0)

  @@index([telegramId, playedAt(sort: Desc)])
  @@index([playedAt])
}

model AdminAuditLog {
  id              String   @id @default(cuid())
  adminTelegramId String
  action          String
  targetType      String
  targetId        String
  beforeJson      Json?
  afterJson       Json?
  createdAt       DateTime @default(now())

  @@index([adminTelegramId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}
