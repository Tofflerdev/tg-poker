# Database
DATABASE_URL=postgresql://poker:poker@localhost:5432/poker_db

# Telegram
BOT_TOKEN=your_bot_token_here

# Server
NODE_ENV=development
PORT=3000

# Enables the dev-only auth bypass. MUST be unset or false in production.
# ALLOW_DEV_AUTH=false

# === Observability (Phase 5 / Plan 05-02) — both optional, graceful no-op if absent ===

# Sentry server DSN. Leave empty in dev; set in prod for error tracking.
# SENTRY_DSN=https://...@sentry.io/...

# PostHog server API key. Leave empty in dev; set in prod for analytics.
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://app.posthog.com  # override only for self-hosted PostHog

# === Admin Panel (Phase 5 / Plan 05-03) ===

# JWT_SECRET — required for production. Booting NODE_ENV=production with this empty exits with code 1.
# Dev fallback is an ephemeral process-local secret (warn logged once).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=

# Admin username and password. Single admin user only — multi-admin is v1.1+.
# Required for the admin panel login at /admin (lazy-loaded SPA).
# ADMIN_USER=admin
# ADMIN_PASS=change-me-in-prod

# === Crypto Pay deposits (crypto-payments-rake phase 4 §D) ===

# Crypto Pay app token from @CryptoBot. When empty, deposits are disabled
# (dev/play-money still works). The webhook lives at POST /api/crypto/webhook.
# CRYPTO_PAY_TOKEN=

# Set to true to hit the Crypto Pay testnet (https://testnet-pay.crypt.bot/api).
# CRYPTO_PAY_TESTNET=false

# === Playtest bots (server/bot/) ===

# When truthy, the SessionRecorder appends every action + hand result to
# sessions/<ts>.jsonl for offline oracle/analysis. Leave unset in normal runs.
# RECORD_SESSIONS=1
