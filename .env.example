# Database
DATABASE_URL=postgresql://poker:poker@localhost:5432/poker_db

# Telegram
BOT_TOKEN=your_bot_token_here

# Server
NODE_ENV=development
PORT=3000

# Enables the dev-only auth bypass. MUST be unset or false in production.
# ALLOW_DEV_AUTH=false

# === Observability (Phase 5 / Plan 05-02) — both optional, graceful no-op if absent ===

# Sentry server DSN. Leave empty in dev; set in prod for error tracking.
# SENTRY_DSN=https://...@sentry.io/...

# PostHog server API key. Leave empty in dev; set in prod for analytics.
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://app.posthog.com  # override only for self-hosted PostHog
