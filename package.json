{
  "name": "poker-mvp",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "npm run build && node dist/server/index.js",
    "dev:all": "concurrently \"npm run dev\" \"cd client && npm run dev\"",
    "test": "vitest run --config vitest.config.server.ts && cd client && vitest run",
    "test:server": "vitest run --config vitest.config.server.ts",
    "test:client": "cd client && vitest run",
    "test:watch": "vitest --config vitest.config.server.ts",
    "test:coverage": "vitest run --config vitest.config.server.ts --coverage && cd client && vitest run --coverage"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/crypto-js": "^4.2.2",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "pg": "^8.19.0",
    "pokersolver": "^2.1.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.18.0",
    "@types/socket.io": "^3.0.2",
    "@vitest/coverage-v8": "^1.6.1",
    "concurrently": "^9.2.1",
    "prisma": "^7.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^1.6.1"
  }
}
